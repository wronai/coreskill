# evo-engine Simulation Dockerfile
# Automated text chat simulation with evolutionary skill building

FROM python:3.12-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    espeak-ng \
    git \
    curl \
    jq \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python dependencies
COPY requirements.txt requirements-test.txt ./
RUN pip install --no-cache-dir -r requirements.txt -r requirements-test.txt 2>/dev/null || \
    pip install --no-cache-dir litellm requests rich pytest 2>/dev/null || true

# Copy project
COPY . /app/

# Create necessary directories
RUN mkdir -p /app/logs/simulation /app/logs/evo /app/logs/nfo /app/logs/skills

# Set environment
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV EVO_DISABLE_LOCAL=1

# Default: run simulation with 3 iterations
CMD ["python", "scripts/simulate.py", "--iterations", "3", "--verbose"]
