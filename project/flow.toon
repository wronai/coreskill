  websocket_chat(ws:WebSocket)                            fan=27   !! side-effects
  run_diagnostic(skill_name:str, specific_error:str) → DiagnosisReport fan=26   !! side-effects
  create_skill(name, desc)                                fan=25   !! side-effects
  _run_file_input_loop(sm, evo, llm, intent, logger, conv, identity, memory) → AnalysisResult fan=24   !! side-effects
  exec_skill(name, version, inp)                          fan=23   !! side-effects
  execute(params:dict) → dict                             fan=23   !! side-effects
  search_by_content(query, path, extensions, recursive, case_sensitive) fan=23   !! side-effects
  run_scenario(scenario:dict) → SimulationResult          fan=22   !! side-effects
  generate_html(source_file, title, template, include_toc) fan=22   !! side-effects
  _recommend_models_live(params:Dict, goal_str:str) → Dict[str, Any] fan=22   !! side-effects

