{
  "capability": "local_computer_discovery",
  "description": "Text transformation and analysis",
  "version_structure": "flat",
  "interface": {
    "input": {
      "text": "str"
    },
    "output": {
      "result": "any"
    }
  },
  "constraints": {
    "max_lines": 349,
    "min_quality_score": 0.5,
    "forbidden_imports": []
  },
  "evolution_rules": {
    "auto_create_from_query": true,
    "max_auto_versions": 5,
    "promote_after_n_successes": 3
  }
}