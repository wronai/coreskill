# ============================================================================
# CoreSkill — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# The system works without API keys (uses Ollama local mode by default).
#
# QUICK START:
#   1. cp .env.example .env
#   2. Edit .env with your settings
#   3. taskfile run deploy
#
# ============================================================================

# ─── VPS Configuration (for production deploy) ────────────────────────────
#
# Wystarczy podać IP VPS i ścieżkę do klucza SSH - reszta dzieje się automatycznie!
#
# Example:
#   VPS_IP=123.456.789.012
#   VPS_USER=deploy
#   VPS_SSH_KEY=~/.ssh/id_ed25519

# VPS IP address (required for production deploy)
VPS_IP=

# SSH user on VPS (default: deploy)
VPS_USER=deploy

# SSH private key path (default: ~/.ssh/id_ed25519)
VPS_SSH_KEY=~/.ssh/id_ed25519

# ─── API Keys (optional, can also be set via /apikey in CLI) ────────────────

# OpenRouter (free tier available, recommended for tiered LLM)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic (paid, optional)
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── LLM Configuration ─────────────────────────────────────────────────────

# Default model (OpenRouter format)
# Examples: qwen/qwen2.5:1.5b, anthropic/claude-3-haiku, openai/gpt-4o-mini
DEFAULT_MODEL=qwen/qwen2.5:1.5b

# Ollama host (for local models)
# Use 'host.docker.internal:11434' when running in Docker
# Use 'localhost:11434' when running natively
OLLAMA_HOST=http://host.docker.internal:11434

# ─── Local Development Settings ──────────────────────────────────────────────

# Enable verbose logging
EVO_VERBOSE=0

# Disable local LLM models (force API usage)
# EVO_DISABLE_LOCAL=1

# ─── Production Deployment Settings (PROD ENV) ─────────────────────────────
#
# Required for: taskfile --env prod run deploy
# These variables are used when deploying to production server.
#
# STEP 1: Configure domain and ports
# STEP 2: Set up container registry (GitHub Container Registry, Docker Hub, etc.)
# STEP 3: Configure SSH in Taskfile.yml 'prod' environment
#

# Production domain (without https://)
# Example: coreskill.example.com
DOMAIN=

# Registry for Docker images
# GitHub Container Registry: ghcr.io/yourorg
# Docker Hub: yourdockerhub
REGISTRY=

# Image tag (use git SHA or version for production)
# TAG=v1.0.0
# TAG=latest
TAG=latest

# ─── SSH Configuration (for remote deploy) ─────────────────────────────────
#
# Add these to Taskfile.yml → environments → prod:
#
#   ssh_host: your-server.com        # Production server hostname/IP
#   ssh_user: deploy                   # SSH user (needs Docker/Podman access)
#   ssh_key: ~/.ssh/id_ed25519         # SSH private key path
#   ssh_port: 22                       # SSH port (optional, default: 22)
#
# Example Taskfile.yml prod config:
#
# environments:
#   prod:
#     desc: Production environment
#     ssh_host: coreskill.example.com
#     ssh_user: deploy
#     ssh_key: ~/.ssh/id_ed25519
#     container_runtime: podman
#     service_manager: quadlet
#     env_file: .env.prod
#     variables:
#       DOMAIN: coreskill.example.com
#       REGISTRY: ghcr.io/wronai
#
# ─── Application Settings ────────────────────────────────────────────────────

# Application name (used for containers, services)
APP_NAME=coreskill

# Ports (local development)
CHAT_PORT=3000
API_PORT=8001

# ─── Security ────────────────────────────────────────────────────────────────

# CORS origins (comma-separated for production)
# CORS_ORIGINS=https://coreskill.example.com,https://app.coreskill.example.com

# Secret key for session/JWT (generate with: openssl rand -hex 32)
# SECRET_KEY=

# ─── External Services ───────────────────────────────────────────────────────

# Web search API key (Tavily, Serper, etc.)
# SEARCH_API_KEY=

# Text-to-Speech provider (elevenlabs, openai, edge, etc.)
# TTS_PROVIDER=edge

# Speech-to-Text provider (openai, whisper-local, etc.)
# STT_PROVIDER=whisper-local

# ============================================================================
# SZYBKI START — KONFIGURACJA VPS (3 kroki)
# ============================================================================
#
# 1. Utwórz parę kluczy SSH (jeśli nie masz):
#    ssh-keygen -t ed25519 -f ~/.ssh/id_ed25519 -C "coreskill"
#
# 2. Skopiuj klucz publiczny na VPS jako root:
#    ssh-copy-id -i ~/.ssh/id_ed25519.pub root@TWÓJ_VPS_IP
#
# 3. Uzupełnij .env i wdróż wszystko:
#    echo "VPS_IP=twój.vps.ip.adres" >> .env
#    taskfile --env prod run deploy-all
#
# Gotowe! Aplikacje będą dostępne pod:
#   • Web/SaaS:     http://TWÓJ_VPS_IP:3000
#   • API:          http://TWÓJ_VPS_IP:8001
#   • Desktop:      http://TWÓJ_VPS_IP:8080
#
# Lokalnie (bez VPS):
#   • Web local:    taskfile run deploy-web-local
#   • Desktop:      taskfile run deploy-desktop-local
#
# ============================================================================
# LOCAL REQUIREMENTS CHECKLIST
# ============================================================================
#
# Lokalny development (taskfile run deploy):
#
#   [ ] Docker: https://docs.docker.com/get-docker/
#   [ ] Docker Compose v2
#   [ ] Ports 3000, 8001 wolne
#
# Produkcja na VPS (taskfile --env prod run deploy-all):
#
#   [ ] VPS z SSH dostępem
#   [ ] VPS_IP ustawiony w .env
#   [ ] Klucz SSH skopiowany (ssh-copy-id)
#   [ ] Zalogowany do registry: docker login ghcr.io -u USER
#
# ============================================================================
