# evo-engine Test Dockerfile
# Fully automated testing environment with pytest

FROM python:3.12-slim

# Install system dependencies for skills (espeak, git, basic tools)
RUN apt-get update && apt-get install -y \
    git \
    curl \
    jq \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python test dependencies first (layer caching)
COPY requirements-test.txt .
RUN pip install --no-cache-dir -r requirements-test.txt

# Copy project code
COPY . /app/

# Set Python path and environment
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV EVO_TEST_MODE=1
ENV EVO_SKIP_LLM=1

# Health check
HEALTHCHECK --interval=10s --timeout=5s --start-period=5s \
    CMD python -c "from cores.v1 import IntentEngine; print('OK')" || exit 1

# Default: run all tests
CMD ["python", "-m", "pytest", "tests/", "-v", "--tb=short", "--color=yes"]
