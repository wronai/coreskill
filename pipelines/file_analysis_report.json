{
  "name": "file_analysis_report",
  "description": "Analyze directory, find documents, read content, generate report with findings",
  "version": "1.0.0",
  "steps": [
    {
      "skill": "file_manager",
      "version": "v1",
      "input": {
        "action": "list",
        "path": "{directory}",
        "recursive": true,
        "limit": 50
      },
      "output_key": "files"
    },
    {
      "skill": "document_reader",
      "version": "v1",
      "input": {
        "action": "info",
        "file": "{files.items.0.path}"
      },
      "output_key": "doc_info"
    },
    {
      "skill": "document_reader",
      "version": "v1",
      "input": {
        "action": "read",
        "file": "{files.items.0.path}",
        "max_chars": 2000
      },
      "output_key": "doc_content"
    },
    {
      "skill": "notes",
      "version": "v1",
      "input": {
        "action": "add",
        "title": "File Analysis: {directory}",
        "content": "Directory: {directory}\nFiles found: {files.count}\n\nDocument: {files.items.0.name}\nType: {doc_info.type}\nSize: {doc_info.size_human}\n\nContent Preview:\n{doc_content.content}",
        "tags": ["analysis", "files", "documents"]
      },
      "output_key": "analysis_note"
    }
  ],
  "created_at": "2026-03-04T17:00:00Z"
}
