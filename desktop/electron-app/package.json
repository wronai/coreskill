{
  "name": "coreskill-desktop",
  "version": "2.0.0",
  "description": "CoreSkill AI Assistant — Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-linux": "electron-builder --linux AppImage",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac"
  },
  "build": {
    "appId": "ai.coreskill.desktop",
    "productName": "CoreSkill",
    "files": [
      "main.js",
      "package.json"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  }
}
