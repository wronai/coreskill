{
  "description": "CoreSkill System Configuration",
  "version": "1.0.0",
  "updated": "2026-03-04",
  "system": {
    "name": "CoreSkill",
    "version": "1.0.0",
    "debug": false,
    "verbose": false
  },
  "limits": {
    "max_evo_iterations": 5,
    "max_skill_iterations": 3,
    "request_timeout": 30,
    "llm_timeout": 60,
    "intent_timeout": 10
  },
  "cooldowns": {
    "rate_limit": 60,
    "demotion": 300,
    "failure_threshold": 3,
    "success_recovery": 2
  },
  "paths": {
    "skills_dir": "skills",
    "logs_dir": "logs",
    "config_dir": "config",
    "state_file": ".evo_state.json"
  },
  "features": {
    "enable_voice": true,
    "enable_auto_heal": true,
    "enable_self_reflection": true,
    "enable_pipeline_logging": true,
    "enable_skill_logging": true
  },
  "llm": {
    "default_temperature": 0.7,
    "default_max_tokens": 4096,
    "intent_temperature": 0.3,
    "evolve_temperature": 0.3,
    "chat_temperature": 0.7,
    "intent_max_params": 3.0,
    "min_params": 2.0
  },
  "intent": {
    "confidence_threshold": 0.40,
    "sbert_threshold": 0.70,
    "tfidf_threshold": 0.45,
    "bow_threshold": 0.35,
    "low_threshold_factor": 0.6,
    "min_threshold": 0.25,
    "similarity_min": 0.3,
    "enable_embeddings": true,
    "enable_local_llm": true,
    "enable_remote_llm": true,
    "training_file": "intent_training.json",
    "embedding_model": "paraphrase-multilingual-MiniLM-L12-v2",
    "tfidf_fallback": true,
    "local_llm_models": [
      "qwen3:4b",
      "qwen2.5:3b",
      "qwen2.5-coder:3b",
      "gemma3:4b",
      "phi4-mini",
      "llama3.2:3b"
    ]
  },
  "blocking": {
    "blocked_commands": [
      "rm -rf /",
      "mkfs",
      "dd if=/dev/zero",
      "format",
      "fdisk",
      ":(){ :|:& };:"
    ],
    "blocked_imports": [
      "os.system",
      "subprocess.call",
      "eval",
      "exec"
    ]
  },
  "filters": {
    "code_model_patterns": [
      "deepseek-coder",
      "starcoder",
      "codellama",
      "codegemma",
      "qwen2.5-coder"
    ],
    "preferred_local_families": [
      "qwen2.5",
      "gemma",
      "llama3",
      "phi3"
    ],
    "excluded_code_models": [
      "coder",
      "starcoder",
      "codellama",
      "codegemma"
    ]
  },
  "categories": {
    "llm": ["model", "temperature", "max_tokens"],
    "tts": ["provider", "speed", "voice", "quality"],
    "stt": ["provider", "duration", "sensitivity"],
    "voice": ["auto_mode", "wake_word", "mute_beep"]
  },
  "provider_tiers": {
    "tts": {
      "espeak": {"tier": "lite", "quality": 3, "speed": 10},
      "pyttsx3": {"tier": "standard", "quality": 5, "speed": 8},
      "coqui": {"tier": "premium", "quality": 9, "speed": 4},
      "piper": {"tier": "premium", "quality": 9, "speed": 5}
    },
    "stt": {
      "vosk": {"tier": "lite", "quality": 6, "speed": 9},
      "whisper": {"tier": "premium", "quality": 9, "speed": 5}
    }
  },
  "tier_order": {
    "lite": 0,
    "standard": 1,
    "premium": 2
  },
  "topic_map": {
    "stt": "voice",
    "tts": "voice",
    "web_search": "web",
    "git_ops": "git",
    "shell": "dev",
    "network_info": "system"
  }
}
